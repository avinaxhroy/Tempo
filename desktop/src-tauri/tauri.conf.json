{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Tempo Desktop",
  "version": "1.0.0",
  "identifier": "com.tempo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tempo Desktop",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost"
    }
  },
  "plugins": {
    "notification": null,
    "global-shortcut": null,
    "autostart": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],

    "macOS": {
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null,
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },

    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "compression": "lzma",
        "startMenuFolder": "Tempo Desktop",
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "minimumWebview2Version": "2.0.0"
      },
      "wix": {
        "language": "en-US"
      }
    },

    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-2",
          "ca-certificates",
          "playerctl"
        ],
        "section": "sound",
        "priority": "optional"
      },
      "rpm": {
        "release": "1",
        "recommends": ["playerctl"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
